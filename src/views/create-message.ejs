<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Message</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("components/header") %>
    <% if(locals.errors) { %>
        <%- include("components/error-list", {errors}) %>
    <% } %>
    <h1>Create Message</h1>
    <form action="/message/create-message" method="POST">
        <div style="margin-bottom: 1rem;">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" required>
        </div>
        <div style="margin-bottom: 1rem;">
            <label for="message" style="display:block; margin-bottom: .5rem;">Message</label>
            <textarea id="message" name="message" rows="5" cols="30" required></textarea>
        </div>
        <button type="submit">Submit</button>
    </form>
</body>
</html>